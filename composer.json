{
  "name": "hypejunction/hypepostadmin",
  "type": "elgg-plugin",
  "description": "Admin interface for managing post schema",
  "homepage": "https://github.com/hypeJunction/Elgg3-hypePostAdmin",
  "keywords": [
    "elgg",
    "plugin",
    "post",
    "admin",
    "schema"
  ],
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Ismayil Khayredinov",
      "email": "ismayil.khayredinov@gmail.com"
    }
  ],
  "extra": {
    "installer-name": "hypepostadmin",
    "elgg-plugin": {
      "id": "hypepostadmin"
    }
  },
  "require": {
    "php": ">=8.3",
    "ext-intl": "*",
    "composer/installers": "^2.0",
    "elgg/elgg": "~7.0.0"
  },
  "autoload": {
    "psr-4": {
      "hypeJunction\\\\PostAdmin\\\\": "classes/hypeJunction/PostAdmin/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  },
  "version": "1.0.4"
}
