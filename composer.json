{
	"name": "hypejunction/hypepostadmin",
	"type": "elgg-plugin",
	"description": "Admin interface for managing post schema",
	"homepage": "https://github.com/hypeJunction/hypepostadmin",
	"keywords": [
		"elgg",
		"plugin",
		"post",
		"admin",
		"schema"
	],
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "hypeJunction"
		}
	],
	"extra": {
		"installer-name": "hypePostAdmin",
		"elgg-plugin": {
			"id": "hypepostadmin"
		}
	},
	"require": {
		"composer/installers": "^2.0",
		"php": ">=8.1",
		"elgg/elgg": "~5.1.0"
	},
	"autoload": {
		"psr-0": {
			"": "classes/"
		}
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true
		}
	}
}
